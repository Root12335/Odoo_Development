<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="module_category_hms" model="ir.module.category">
        <field name="name">HMS</field>
        <field name="description">Hospital management system access rights</field>
        <field name="sequence">20</field>
    </record>

    <record id="group_hms_user" model="res.groups">
        <field name="name">HMS User</field>
        <field name="category_id" ref="hms.module_category_hms"/>
    </record>

    <record id="group_hms_manager" model="res.groups">
        <field name="name">HMS Manager</field>
        <field name="category_id" ref="hms.module_category_hms"/>
    </record>

    <record id="rule_hms_patient_own_records" model="ir.rule">
        <field name="name">HMS Patients: own records only</field>
        <field name="model_id" ref="model_hms_patient"/>
        <field name="groups" eval="[(4, ref('hms.group_hms_user'))]"/>
        <field name="domain_force">[('create_uid', '=', user.id)]</field>
    </record>

    <record id="rule_hms_patient_log_own_records" model="ir.rule">
        <field name="name">HMS Patient Logs: own patient records only</field>
        <field name="model_id" ref="model_hms_patient_log"/>
        <field name="groups" eval="[(4, ref('hms.group_hms_user'))]"/>
        <field name="domain_force">[('patient_id.create_uid', '=', user.id)]</field>
    </record>
</odoo>
