<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_hms_doctor_tree" model="ir.ui.view">
        <field name="name">hms.doctor.tree</field>
        <field name="model">hms.doctors</field>
        <field name="arch" type="xml">
            <tree>
                <field name="first_name"/>
                <field name="last_name"/>
            </tree>
        </field>
    </record>

    <record id="view_hms_doctor_form" model="ir.ui.view">
        <field name="name">hms.doctor.form</field>
        <field name="model">hms.doctors</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="image" widget="image" class="oe_avatar"/>
                        <field name="first_name"/>
                        <field name="last_name"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_hms_doctor" model="ir.actions.act_window">
        <field name="name">Doctors</field>
        <field name="res_model">hms.doctors</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="menu_hms_doctor" name="Doctors" parent="menu_hms_root" action="action_hms_doctor" sequence="30" groups="hms.group_hms_manager"/>
</odoo>
