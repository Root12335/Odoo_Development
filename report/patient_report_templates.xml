<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <template id="patient_status_report">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-set="patient" t-value="doc.sudo()"/>
                <t t-call="web.external_layout">
                    <div class="page">
                        <style>
                            .hms-report {
                                border-top: 4px solid #f36f21;
                                border-right: 3px solid #1e66d0;
                                border-left: 1px solid #d7dbe3;
                                border-bottom: 1px solid #d7dbe3;
                                padding: 22px 26px 18px;
                                font-family: Arial, sans-serif;
                                color: #111827;
                            }
                            .hms-title-row {
                                display: flex;
                                justify-content: space-between;
                                align-items: flex-start;
                                gap: 24px;
                                margin-bottom: 26px;
                            }
                            .hms-title {
                                font-size: 30px;
                                line-height: 1.1;
                                font-weight: 700;
                                color: #e53935;
                                margin: 54px 0 0;
                            }
                            .hms-photo {
                                width: 175px;
                                height: 175px;
                                object-fit: cover;
                                border: 1px solid #d1d5db;
                                background: #f3f4f6;
                            }
                            .hms-info-grid {
                                display: flex;
                                justify-content: space-between;
                                gap: 36px;
                                margin: 14px 0 40px;
                            }
                            .hms-info-col {
                                width: 48%;
                                font-size: 18px;
                                line-height: 1.45;
                            }
                            .hms-info-row {
                                margin-bottom: 4px;
                            }
                            .hms-label {
                                font-weight: 700;
                                color: #111827;
                            }
                            .hms-section-title {
                                text-align: center;
                                font-size: 23px;
                                font-weight: 700;
                                color: #e53935;
                                margin: 14px 0 0;
                            }
                            .hms-table {
                                width: 86%;
                                margin: 0 auto;
                                border-collapse: collapse;
                                table-layout: fixed;
                            }
                            .hms-table th {
                                background: #0b84ff;
                                color: #ffffff;
                                font-size: 19px;
                                font-weight: 700;
                                text-align: left;
                                padding: 10px 12px;
                                border: 1px solid #ffffff;
                            }
                            .hms-table td {
                                background: #c9d5ff;
                                padding: 16px 12px;
                                border: 1px solid #ffffff;
                                font-size: 15px;
                            }
                            .hms-table tr:nth-child(even) td {
                                background: #e1e7ff;
                            }
                        </style>

                        <div class="hms-report">
                            <div class="hms-title-row">
                                <div class="hms-title">Patient Status Report</div>
                                <div>
                                    <img t-if="patient.image" t-att-src="image_data_uri(patient.image)" class="hms-photo" alt="Patient Photo"/>
                                    <div t-else="" class="hms-photo"/>
                                </div>
                            </div>

                            <div class="hms-info-grid">
                                <div class="hms-info-col">
                                    <div class="hms-info-row"><span class="hms-label">Name:</span> <span t-esc="patient.first_name or ''"/> <span t-esc="patient.last_name or ''"/></div>
                                    <div class="hms-info-row"><span class="hms-label">Age:</span> <span t-esc="patient.age or 0"/></div>
                                    <div class="hms-info-row"><span class="hms-label">Department:</span> <span t-esc="patient.department_id.name or ''"/></div>
                                    <div class="hms-info-row"><span class="hms-label">Doctors:</span>
                                        <span t-if="patient.doctor_ids" t-esc="', '.join(patient.doctor_ids.mapped('display_name'))"/>
                                        <span t-else="">-</span>
                                    </div>
                                </div>
                                <div class="hms-info-col">
                                    <div class="hms-info-row"><span class="hms-label">Birth date:</span> <span t-esc="patient.birthdate or ''"/></div>
                                    <div class="hms-info-row"><span class="hms-label">PCR:</span> <span t-esc="patient.cr_ratio or 0.0"/></div>
                                    <div class="hms-info-row"><span class="hms-label">Blood Type:</span>
                                        <span t-esc="dict(patient._fields['blood_type'].selection).get(patient.blood_type, '')"/>
                                    </div>
                                    <div class="hms-info-row"><span class="hms-label">Email:</span> <span t-esc="patient.email or ''"/></div>
                                </div>
                            </div>

                            <div class="hms-section-title">Log History</div>
                            <table class="hms-table">
                                <thead>
                                    <tr>
                                        <th>User</th>
                                        <th>Date</th>
                                        <th>Info</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-set="logs" t-value="patient.log_history_ids.sudo()"/>
                                    <t t-if="logs">
                                        <t t-foreach="logs" t-as="line">
                                            <tr>
                                                <td><span t-esc="line.created_by_id.name or ''"/></td>
                                                <td><span t-esc="line.date or ''"/></td>
                                                <td><span t-esc="line.description or ''"/></td>
                                            </tr>
                                        </t>
                                    </t>
                                    <t t-else="">
                                        <tr>
                                            <td>&nbsp;</td>
                                            <td>&nbsp;</td>
                                            <td>&nbsp;</td>
                                        </tr>
                                        <tr>
                                            <td>&nbsp;</td>
                                            <td>&nbsp;</td>
                                            <td>&nbsp;</td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
